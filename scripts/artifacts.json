[
  {
    "name": "CSS bundles + docs",
    "srcPrefixes": ["core/", "optional/"],
    "buildCmd": "node scripts/bundle.js && npm run docs",
    "outputs": [
      "docs/tokens.md",
      "docs/classes.md",
      "docs/token-index.md",
      "docs/token-index.json",
      "docs/api-index.json",
      "docs/api-index.md",
      "configurator/src/data/api-index.generated.json",
      "configurator/src/data/bundles.generated.json"
    ]
  },
  {
    "name": "configurator api sync",
    "srcPrefixes": ["docs/token-annotations.json", "docs/api-index.json", "bundle.config.json"],
    "buildCmd": "npm run configurator:sync",
    "outputs": [
      "configurator/src/data/api-index.generated.json",
      "configurator/src/data/bundles.generated.json"
    ]
  }
]
