[
  {
    "name": "CSS bundles + docs",
    "srcPrefixes": ["core/", "optional/"],
    "buildCmd": "node scripts/bundle.js && npm run docs",
    "outputs": [
      "docs/tokens.md",
      "docs/classes.md",
      "docs/token-index.md",
      "docs/token-index.json",
      "docs/api-index.json",
      "docs/api-index.md",
      "configurator/src/data/api-index.generated.json"
    ]
  },
  {
    "name": "configurator api sync",
    "srcPrefixes": ["docs/token-annotations.json"],
    "buildCmd": "npm run configurator:sync",
    "outputs": ["configurator/src/data/api-index.generated.json"]
  },
  {
    "name": "sizes-extended tokens",
    "srcPrefixes": ["scripts/gen-sizes-extended.js"],
    "buildCmd": "node scripts/gen-sizes-extended.js > optional/tokens.sizes-extended.css",
    "outputs": ["optional/tokens.sizes-extended.css"]
  }
]
