{
  "name": "slashed-configurator",
  "private": true,
  "version": "0.6.16",
  "description": "Standalone Svelte 5 + Tailwind panel to configure every SLASHED token/knob and generate override CSS. Auto-synced from the framework's generated docs/api-index.json.",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-api.mjs",
    "predev": "node scripts/sync-api.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-api.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-svelte": "^0.468.0",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
