{
  "name": "slashed-configurator",
  "private": true,
  "version": "0.6.4",
  "description": "Standalone Svelte 5 panel to configure every SLASHED token/knob and generate override CSS. Auto-synced from the framework's generated docs/api-index.json.",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-api.mjs",
    "predev": "node scripts/sync-api.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-api.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "check:curation": "node scripts/check-curation.mjs",
    "test": "npm run test:unit && npm run test:components",
    "test:unit": "node --test tests/*.test.js",
    "test:components": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.0",
    "jsdom": "^25.0.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  }
}
