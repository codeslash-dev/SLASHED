#!/bin/sh
set -e

# Lint staged CSS files
STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.css$' || true)
if [ -n "$STAGED_CSS" ]; then
  echo "$STAGED_CSS" | tr '\n' '\0' | xargs -0 npx stylelint
fi

# Rebuild dist bundles and stage them
node scripts/bundle.js
outputs=$(node -e "const c=require('./bundle.config.json'); const b=Array.isArray(c.bundles)?c.bundles:[c]; process.stdout.write(b.map(x=>x.output).join('\n'))")
echo "$outputs" | while IFS= read -r f; do
  [ -n "$f" ] && git add "$f"
done
