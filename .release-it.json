{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "increment": "patch",
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["npm run lint:css"],
    "after:bump": ["npm version ${version} --no-git-tag-version --allow-same-version", "node scripts/version-sync.js", "npm run build"]
  }
}
